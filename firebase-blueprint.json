{
  "entities": {
    "Bookmark": {
      "title": "Bookmark",
      "description": "A bookmark or folder stored in Firestore",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID" },
        "title": { "type": "string", "description": "Title of the bookmark or folder" },
        "url": { "type": "string", "description": "URL of the bookmark" },
        "domain": { "type": "string", "description": "Domain of the bookmark" },
        "type": { "type": "string", "enum": ["link", "folder"], "description": "Type of the item" },
        "parentId": { "type": "string", "description": "Parent folder ID" },
        "category": { "type": "string", "description": "Category of the bookmark" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" },
        "summary": { "type": "string", "description": "AI-generated summary" },
        "uid": { "type": "string", "description": "User ID who owns this bookmark" }
      },
      "required": ["id", "title", "category", "createdAt", "uid"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique User ID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User bookmarks"
    }
  }
}
